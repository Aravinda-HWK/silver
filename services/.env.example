# Rspamd web UI password
RSPAMD_PASSWORD=your_secure_password

# Public IP of this mail server
MAIL_SERVER_IP=

# Grafana admin credentials
GRAFANA_ADMIN_USER=
GRAFANA_ADMIN_PASSWORD=

# Thunder IdP authentication token for policy service (optional)
# Leave empty if Thunder API doesn't require authentication
THUNDER_IDP_TOKEN=

# Please use single quotes for the webhook URL to avoid issues with special characters
GOOGLE_CHAT_WEBHOOK_URL=''